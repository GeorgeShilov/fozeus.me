---
import { navItems, site } from "@/config/site";

type Props = {
  title?: string;
  description?: string;
};

const title = Astro.props.title ? `${Astro.props.title} | ${site.name}` : site.name;
const description = Astro.props.description || site.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <img src="/assets/logo.png" alt="" class="brand-mark" />
        <span>{site.name}</span>
      </a>
      <button class="menu-button" type="button" aria-label="Open navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <a class="brand footer-brand" href="/">
          <img src="/assets/logo.png" alt="" class="brand-mark" />
          <span>{site.name}</span>
        </a>
        <p>
          Personal tech innovation lab for AI, crypto, and digital identity.
        </p>
      </div>
      <div class="footer-links">
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/contact/">Contact</a>
      </div>
    </footer>
    <script>
      const button = document.querySelector(".menu-button");
      const nav = document.querySelector(".site-nav");
      button?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open") || false;
        button.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --ink: #faf5ff;
    --muted: #d8b4fe;
    --line: rgba(217, 70, 239, 0.2);
    --panel: #1a112a;
    --soft: #0f0a1a;
    --accent: #d946ef;
    --accent-strong: #8b5cf6;
    --gold: #f97316;
    --blue: #8b5cf6;
    --shadow: 0 18px 50px rgba(217, 70, 239, 0.1);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--soft);
    color: var(--ink);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    max-width: 100%;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(18px, 5vw, 64px);
    border-bottom: 1px solid rgba(217, 70, 239, 0.2);
    background: rgba(15, 10, 26, 0.92);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .brand-mark {
    display: block;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    object-fit: cover;
    background: transparent;
  }

  .brand-mark-OLD {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 8px;
    background: linear-gradient(135deg, #d946ef, #8b5cf6);
    color: #fff;
    font-size: 17px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 26px);
    color: var(--muted);
    font-size: 15px;
    font-weight: 650;
  }

  .site-nav a:hover {
    color: var(--accent);
  }

  .menu-button {
    display: none;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .menu-button span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 3px auto;
    background: var(--ink);
  }

  .section {
    padding: clamp(58px, 8vw, 104px) clamp(18px, 5vw, 64px);
  }

  .section-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(42px, 8vw, 88px);
    line-height: 0.96;
    letter-spacing: 0;
  }

  h2 {
    max-width: 780px;
    margin: 0 0 18px;
    font-size: clamp(30px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: 0;
  }

  h3 {
    margin: 0 0 10px;
    font-size: 21px;
    line-height: 1.2;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .lead {
    max-width: 720px;
    margin-top: 24px;
    color: #d8b4fe;
    font-size: clamp(18px, 2vw, 22px);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 12px 18px;
    border: 1px solid var(--accent);
    background: linear-gradient(135deg, #d946ef, #8b5cf6);
    color: #fff;
    font-weight: 760;
  }

  .button.secondary {
    border-color: rgba(217, 70, 239, 0.4);
    background: transparent;
    color: var(--ink);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .card {
    border: 1px solid rgba(217, 70, 239, 0.2);
    border-radius: 8px;
    background: rgba(26, 17, 42, 0.7);
    padding: 24px;
    box-shadow: 0 1px 0 rgba(217, 70, 239, 0.03);
  }

  .band {
    background: #0f0a1a;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    padding: 44px clamp(18px, 5vw, 64px);
    border-top: 1px solid var(--line);
    background: #0f0a1a;
  }

  .site-footer p {
    max-width: 520px;
    margin-top: 12px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 16px;
    color: var(--muted);
    font-weight: 650;
  }

  .article-body {
    max-width: 760px;
  }

  .article-body p,
  .article-body li {
    color: #d8b4fe;
    font-size: 18px;
  }

  .article-body p + p,
  .article-body ul + p {
    margin-top: 20px;
  }

  .article-body code,
  pre {
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 780px) {
    .site-header {
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .menu-button {
      display: grid;
    }

    .site-nav {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding-top: 8px;
    }

    .site-nav.is-open {
      display: flex;
    }

    .site-nav a {
      border-top: 1px solid var(--line);
      padding: 12px 0;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .site-footer {
      flex-direction: column;
    }
  }
</style>
