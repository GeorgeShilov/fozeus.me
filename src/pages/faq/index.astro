---
import Layout from "@/layouts/Layout.astro";

const faqs = [
  ["What is Fozeus?", "Fozeus is an NFT and crypto-native project building at the intersection of blockchain, SocialFi, GameFi, and AI — with the FZS token powering ecosystem utility."],
  ["What can I do with Fozeus NFTs?", "Fozeus NFTs unlock GameFi assets, SocialFi reputation, governance rights, and cross-platform utility within the ecosystem."],
  ["What is the FZS token?", "FZS is the native utility token of the Fozeus ecosystem. It is used for governance, staking, in-game rewards, and access to premium features."],
  ["How do I get involved?", "Follow the blog for updates, reach out via the contact page for partnerships, and stay tuned for NFT drops and token announcements."]
];
---

<Layout title="FAQ">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">FAQ</p>
      <h1>Clear answers before your first move.</h1>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details class="card">
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-top: 40px;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 20px;
  }

  details p {
    margin-top: 14px;
  }
</style>
