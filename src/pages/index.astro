---
import Layout from '@/layouts/Layout.astro'; import LeadDialog from '@/components/LeadDialog.astro';
---
<Layout title="Independent digital atelier"><main class="atelier"><nav class="atelier-nav"><b>FOZEUS®</b><span>Independent digital atelier · Est. 2017</span><button data-lead>Commission a project</button></nav><section class="portrait"><div class="note">Strategy<br/>Identity<br/>Digital</div><img src="/assets/generated/hero-atelier.jpg" alt="Surreal digital design atelier"/><div class="intro"><p>Selected practice / 2026</p><h1>Ideas with a pulse.</h1><p>Fozeus shapes identities, interfaces and digital places for people building culture—not clutter.</p></div></section><section class="manifesto"><em>“</em><p>Make the strange clear.<br/>Make the useful memorable.</p><span>Our working principle</span></section><section class="ledger"><h2>Studio ledger</h2><ol><li><span>01</span><b>New identities</b><p>Position, voice and systems that hold together.</p></li><li><span>02</span><b>Digital experiences</b><p>Editorial websites and products with rhythm.</p></li><li><span>03</span><b>Creative direction</b><p>A visual world your team can keep extending.</p></li></ol></section><aside class="maker"><img src="/assets/generated/creator-portrait.jpg" alt="Portrait of an independent creative director"/><blockquote>Small team. Close collaboration. No relay race between strategy and craft.</blockquote><button class="ink" data-lead>Start with a note →</button></aside><LeadDialog /></main></Layout>
<style>:global(.site-header),:global(.site-footer){display:none}.atelier{background:#f0eadf;color:#211e1a;min-height:100vh;font-family:Georgia,serif}.atelier-nav{display:grid;grid-template-columns:1fr 2fr auto;align-items:center;padding:22px 4vw;border-bottom:1px solid #29251f}.atelier-nav span{text-align:center;font-size:.8rem;text-transform:uppercase;letter-spacing:.15em}.atelier-nav button,.ink{border:0;background:none;text-decoration:underline;font:inherit;cursor:pointer}.portrait{display:grid;grid-template-columns:160px minmax(300px,1fr) 1fr;gap:2vw;padding:4vw}.portrait img{width:100%;height:70vh;object-fit:cover;filter:saturate(.8)}.note{writing-mode:vertical-rl;text-transform:uppercase;letter-spacing:.2em}.intro{align-self:end;padding-bottom:5vw}.intro h1{font-size:clamp(4rem,10vw,10rem);line-height:.75;letter-spacing:-.08em;margin:.2em 0}.intro p{max-width:480px;font-size:1.15rem}.manifesto{min-height:65vh;padding:8vw;display:grid;place-content:center;background:#ef5b38;color:#1f1915;text-align:center}.manifesto em{font-size:7rem;line-height:.2}.manifesto p{font-size:clamp(2.8rem,6vw,6rem);line-height:1.05}.ledger{padding:8vw}.ledger h2{font-size:4rem}.ledger ol{list-style:none;padding:0}.ledger li{display:grid;grid-template-columns:80px 1fr 1fr;border-top:1px solid;padding:24px 0;font-size:1.2rem}.maker{display:grid;grid-template-columns:1fr 1.2fr;gap:5vw;align-items:center;padding:5vw;background:#28241f;color:#f5eee2}.maker img{width:100%;max-height:640px;object-fit:cover}.maker blockquote{font-size:clamp(2rem,4vw,4rem);margin:0}.maker .ink{color:#f5eee2}@media(max-width:760px){.atelier-nav{grid-template-columns:1fr auto}.atelier-nav span{display:none}.portrait{grid-template-columns:1fr}.note{writing-mode:initial}.portrait img{height:55vh}.intro h1{font-size:5rem}.ledger li,.maker{grid-template-columns:1fr}.maker blockquote{font-size:2rem}}</style>
