---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const sorted = [...posts].sort(
  (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);
const latest3 = sorted.slice(0, 3);
---

<Layout title="Fozeus NFT — The Future Begins Here" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>
    <div class="hero-copy">
      <p class="eyebrow">Fozeus NFT</p>
      <h1>Discover the unlimited possibilities of digital assets.</h1>
      <p class="lead">
        Fozeus is an NFT and crypto-native project harnessing the power of blockchain, SocialFi,
        GameFi, and AI to build remarkable digital experiences with true on-chain utility.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Explore the ecosystem</a>
        <a class="button secondary" href="/blog/">Read field notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Fozeus signal summary">
      <div>
        <span>Core view</span>
        <strong>NFTs, SocialFi, GameFi, Metaverse</strong>
      </div>
      <div>
        <span>Signals</span>
        <strong>Blockchain, AI, FZS token utility</strong>
      </div>
      <div>
        <span>Focus</span>
        <strong>Web3 digital asset innovation</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Builders need on-chain identity before they need a platform.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Ecosystem architecture</p>
      <h2>One view for the next generation of digital ownership.</h2>
      <div class="grid">
        <article class="card">
          <h3>NFT collections</h3>
          <p>Create, trade, and collect unique digital assets with verifiable scarcity and on-chain provenance.</p>
        </article>
        <article class="card">
          <h3>SocialFi layer</h3>
          <p>Turn community engagement into owned reputation and tokenized rewards across Web3 social graphs.</p>
        </article>
        <article class="card">
          <h3>GameFi mechanics</h3>
          <p>Build play-to-earn experiences where in-game assets are real NFTs with cross-platform portability.</p>
        </article>
      </div>
    </div>
  </section>

  {latest3.length > 0 && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Latest field notes</p>
        <h2>Fresh research from the Fozeus ecosystem.</h2>
        <div class="latest-row">
          {latest3.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background: linear-gradient(135deg, #0f0a1a 0%, #1a112a 40%, #2d1b4e 70%, #0f0a1a 100%);
    color: #fff;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    opacity: 0.45;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    top: -120px;
    right: -80px;
    background: radial-gradient(circle, #d946ef 0%, transparent 70%);
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    bottom: -100px;
    left: -60px;
    background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(216, 180, 254, 0.85);
  }

  .hero-panel {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(217, 70, 239, 0.25);
    border-radius: 8px;
    background: rgba(26, 17, 42, 0.7);
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }

  .hero-panel div {
    border-bottom: 1px solid rgba(217, 70, 239, 0.15);
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #d8b4fe;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #faf5ff;
    font-size: 20px;
    line-height: 1.2;
  }

  .hero .button {
    border-color: var(--accent);
    background: linear-gradient(135deg, #d946ef, #8b5cf6);
    color: #fff;
  }

  .hero .button.secondary {
    border-color: rgba(217, 70, 239, 0.4);
    background: transparent;
    color: #fff;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #d946ef;
    padding-left: 16px;
  }

  .latest-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: 36px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .latest-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
