---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const featured = posts.find((post) => post.featured) || posts[0];
---

<Layout title="Fozeus NFT — The Future Begins Here" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Fozeus NFT</p>
      <h1>Discover the unlimited possibilities of digital assets.</h1>
      <p class="lead">
        Fozeus is an NFT and crypto-native project harnessing the power of blockchain, SocialFi,
        GameFi, and AI to build remarkable digital experiences with true on-chain utility.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Explore the ecosystem</a>
        <a class="button secondary" href="/blog/">Read field notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Fozeus signal summary">
      <div>
        <span>Core view</span>
        <strong>NFTs, SocialFi, GameFi, Metaverse</strong>
      </div>
      <div>
        <span>Signals</span>
        <strong>Blockchain, AI, FZS token utility</strong>
      </div>
      <div>
        <span>Focus</span>
        <strong>Web3 digital asset innovation</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Builders need on-chain identity before they need a platform.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Ecosystem architecture</p>
      <h2>One view for the next generation of digital ownership.</h2>
      <div class="grid">
        <article class="card">
          <h3>NFT collections</h3>
          <p>Create, trade, and collect unique digital assets with verifiable scarcity and on-chain provenance.</p>
        </article>
        <article class="card">
          <h3>SocialFi layer</h3>
          <p>Turn community engagement into owned reputation and tokenized rewards across Web3 social graphs.</p>
        </article>
        <article class="card">
          <h3>GameFi mechanics</h3>
          <p>Build play-to-earn experiences where in-game assets are real NFTs with cross-platform portability.</p>
        </article>
      </div>
    </div>
  </section>

  {featured && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Featured note</p>
        <h2>Start with digital ownership.</h2>
        <PostCard post={featured} />
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background: linear-gradient(135deg, #020617 0%, #0f172a 40%, #1e3a8a 70%, #0e7490 100%);
    color: #fff;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  .hero-panel div {
    border-bottom: 1px solid #d9dee8;
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #5c6676;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #101828;
    font-size: 20px;
    line-height: 1.2;
  }

  .hero .button {
    border-color: var(--accent);
    background: var(--accent);
    color: #021016;
  }

  .hero .button.secondary {
    border-color: rgba(255, 255, 255, 0.55);
    background: transparent;
    color: #fff;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #06b6d4;
    padding-left: 16px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }
  }
</style>
