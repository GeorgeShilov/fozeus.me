---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Ecosystem Tiers">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Participation</p>
      <h1>Choose your level of engagement.</h1>
      <p class="lead">
        Start with free ecosystem access, then unlock deeper NFT utility, GameFi rewards, and
        community governance as you grow with the platform.
      </p>
      <div class="grid pricing">
        <article class="card"><h3>Explorer</h3><p>Browse NFT collections, read field notes, follow SocialFi channels, and join the community.</p><strong>Free</strong></article>
        <article class="card"><h3>Collector</h3><p>Mint and trade Fozeus NFTs, earn FZS rewards, access holder channels, and unlock early drops.</p><strong>NFT Holders</strong></article>
        <article class="card"><h3>Builder</h3><p>Create on the Fozeus platform, deploy custom GameFi experiences, and participate in governance.</p><strong>Partners</strong></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing {
    margin-top: 42px;
  }

  strong {
    display: block;
    margin-top: 28px;
    font-size: 30px;
  }
</style>
