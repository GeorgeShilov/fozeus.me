---
import type { BlogPost } from "@/data/blog";

const { post } = Astro.props as { post: BlogPost };
---

<article class="post-card">
  <img src={post.heroImage} alt="" loading="lazy" />
  <div>
    <p class="meta">{post.category} / {new Date(post.pubDate).toLocaleDateString("ru-RU")}</p>
    <h3><a href={`/blog/${post.slug}/`}>{post.title}</a></h3>
    <p>{post.description}</p>
    <div class="tags">
      {post.tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>

<style>
  .post-card {
    display: grid;
    grid-template-rows: 180px 1fr;
    overflow: hidden;
    border: 1px solid rgba(217, 70, 239, 0.2);
    border-radius: 8px;
    background: rgba(26, 17, 42, 0.7);
    box-shadow: 0 1px 0 rgba(217, 70, 239, 0.03);
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #1a112a;
  }

  div {
    padding: 22px;
  }

  .meta {
    margin-bottom: 10px;
    color: #d946ef;
    font-size: 13px;
    font-weight: 800;
  }

  h3 a:hover { color: var(--accent); text-decoration: underline; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
    padding: 0;
  }

  span {
    border: 1px solid rgba(217, 70, 239, 0.25);
    border-radius: 999px;
    padding: 4px 9px;
    color: #d8b4fe;
    font-size: 12px;
    font-weight: 700;
  }
</style>
