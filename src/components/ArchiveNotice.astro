---
import { site } from "@/config/site";
---

<section class="archive-notice">
  <div>
    <strong>Launch sprint</strong>
    <p>
      Fozeus is being built as a fast Web3 pilot: domain, generated brand assets,
      content, deployment, and iteration all move through one repeatable workflow.
    </p>
  </div>
  <a href={`mailto:${site.email}`}>Start a sprint</a>
</section>

<style>
  .archive-notice {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 16px clamp(18px, 5vw, 64px);
    border-bottom: 1px solid rgba(217, 70, 239, 0.2);
    background: linear-gradient(135deg, #1a112a, #2d1b4e);
  }

  strong {
    display: block;
    margin-bottom: 2px;
    color: #faf5ff;
  }

  p {
    max-width: 860px;
    font-size: 14px;
    color: #d8b4fe;
  }

  a {
    flex: 0 0 auto;
    color: #d946ef;
    font-weight: 800;
  }

  @media (max-width: 700px) {
    .archive-notice {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
